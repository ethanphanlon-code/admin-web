# CoHomed Admin Dashboard - Environment Variables
# Copy this file to .env.local and fill in your actual values

# ─────────────────────────────────────────────
# Core Settings
# ─────────────────────────────────────────────
NODE_ENV=development
NEXT_ENV=development
NEXT_PUBLIC_RELEASE_VERSION=1.0.0

# ─────────────────────────────────────────────
# Supabase (same project as the mobile app)
# ─────────────────────────────────────────────
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anon/publishable key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — BYPASSES RLS, server-side only
# Find in Supabase Dashboard → Settings → API → service_role (secret)
# NEVER commit this or expose it to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# Sentry Error Monitoring
# ─────────────────────────────────────────────
# Sentry project DSN for browser/client errors
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Sentry auth token for source map uploads
NEXT_PUBLIC_SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Server-side Sentry DSN
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# Sentry credentials for source map uploads
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ─────────────────────────────────────────────
# Analytics (Optional)
# ─────────────────────────────────────────────
# PostHog or similar analytics
NEXT_PUBLIC_ANALYTICS_KEY=your-analytics-key

# ─────────────────────────────────────────────
# Admin Features
# ─────────────────────────────────────────────
# Enable/disable specific admin features
ENABLE_AUDIT_LOGGING=true
ENABLE_MONITORING=true
ENABLE_DATA_EXPORTS=true
ENABLE_USER_DELETION=true

# ─────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────
# API rate limiting
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=100

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000
